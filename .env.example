# =========================================================================
# Ronny J Ops — environment variables
#
# Copy this file to `.env.local` for local dev, and set the same keys in
# your Vercel project (Production, Preview, Development) before deploying.
#
# Never commit `.env.local`. Only this `.env.example` is checked in.
# =========================================================================

# ---- Site / app --------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Used for OAuth redirect + vendor portal links. Set to your prod domain
# on Vercel (e.g. https://ops.ronnyjlistenup.com).

# ---- Supabase ----------------------------------------------------------
# From the Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...public-anon-key...
# Server-only. Bypasses RLS — NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...
# Used by the Supabase CLI for migrations:
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ---- Inngest -----------------------------------------------------------
# From the Inngest dashboard -> Manage -> Keys
INNGEST_EVENT_KEY=iek_...
INNGEST_SIGNING_KEY=signkey-prod-...
# In local dev, leaving these blank and running `npm run inngest:dev`
# will use the Inngest dev server at http://localhost:8288

# ---- Twilio ------------------------------------------------------------
# From the Twilio console -> Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# A2P 10DLC-registered sending number (+1...). Must be on an approved campaign.
TWILIO_SMS_FROM=+1XXXXXXXXXX
# WhatsApp sender (phase 2). Format: whatsapp:+14155238886 (sandbox) or your
# verified WABA sender.
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
# Messaging Service SID (recommended so Twilio handles sender pool + fallback)
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Resend ------------------------------------------------------------
# From resend.com -> API Keys
RESEND_API_KEY=re_...
# Verified sending domain (DKIM + SPF + Return-Path must all be green)
RESEND_FROM_EMAIL=ops@ronnyjlistenup.com
RESEND_FROM_NAME=Ronny J Ops

# ---- Google (Calendar sync + OAuth) -----------------------------------
# From Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must match a redirect URI you registered:
# http://localhost:3000/api/google/callback  (dev)
# https://ops.ronnyjlistenup.com/api/google/callback  (prod)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ---- Anthropic (Claude Agent SDK) -------------------------------------
# From console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---- Cron / webhook shared secret --------------------------------------
# Random 32+ char string. Used to authenticate inbound webhooks and
# cron endpoints so they can't be called from the public internet.
# Generate with: `openssl rand -hex 32`
WEBHOOK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
